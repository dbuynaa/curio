# Since .env is gitignored, you can use .env.example to build a new `.env` file when you clone the repo.
# Keep this file up-to-date when you add new variables to \`.env\`.

# This file will be committed to version control, so make sure not to have any secrets in it.
# If you are cloning this repo, create a copy of this file named `.env` and populate it with your secrets.

# Pooled connection string used by the app at runtime (@vercel/postgres createPool).
# Supabase: use the pooler host on port 6543.
# Neon: use the `-pooler` host (for example `ep-xxx-pooler.region.aws.neon.tech`).
POSTGRES_URL="postgres://postgres.[USERNAME]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?workaround=supabase-pooler.vercel"

# Optional direct connection string for migrations, drizzle-kit, and local scripts.
# Required when POSTGRES_URL is a direct/non-pooled URL (for example Neon without `-pooler`).
# Supabase: use the direct host on port 5432.
# Neon: use the non-pooler host (for example `ep-xxx.region.aws.neon.tech`).
# POSTGRES_URL_NON_POOLING="postgres://postgres.[USERNAME]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"


# You can generate the secret via 'openssl rand -base64 32' on Unix
# @see https://www.better-auth.com/docs/installation
AUTH_SECRET='supersecret'

# Preconfigured Discord OAuth provider, works out-of-the-box
# @see https://www.better-auth.com/docs/authentication/discord
AUTH_DISCORD_ID=''
AUTH_DISCORD_SECRET=''
